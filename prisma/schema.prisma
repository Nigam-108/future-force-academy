generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
  SUB_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum LanguageCode {
  EN
  GU
  HI
}

enum QuestionType {
  SINGLE_CORRECT
  TRUE_FALSE
  ASSERTION_REASON
  MULTI_CORRECT
  MATCH_THE_FOLLOWING
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  APPROVED
  ACTIVE
  REJECTED
}

enum TestMode {
  PRACTICE
  LIVE
  ASSIGNED
}

enum TestStructureType {
  SINGLE
  SECTIONAL
}

enum TestVisibilityStatus {
  DRAFT
  LIVE
  CLOSED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  EXPIRED
}

model User {
  id                String       @id @default(cuid())
  fullName          String
  email             String       @unique
  mobileNumber      String?
  passwordHash      String
  role              UserRole     @default(STUDENT)
  status            UserStatus   @default(ACTIVE)
  preferredLanguage LanguageCode @default(EN)
  emailVerified     Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  questionsCreated  Question[]    @relation("QuestionCreatedBy")
  questionsApproved Question[]    @relation("QuestionApprovedBy")
  testsCreated      Test[]
  attempts          TestAttempt[]

  /// Batches created by this admin user.
  createdBatches Batch[] @relation("BatchCreatedBy")

  /// Batch memberships for student access grouping.
  studentBatches StudentBatch[] @relation("StudentBatchMembership")
}

model Question {
  id            String          @id @default(cuid())
  createdById   String?
  approvedById  String?
  type          QuestionType
  difficulty    DifficultyLevel @default(MEDIUM)
  status        QuestionStatus  @default(DRAFT)
  questionText  String
  optionA       String?
  optionB       String?
  optionC       String?
  optionD       String?
  correctAnswer String?
  explanation   String?
  tags          String[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  createdBy     User?          @relation("QuestionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy    User?          @relation("QuestionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  testQuestions TestQuestion[]
}

model Test {
  id                String               @id @default(cuid())
  createdById       String?
  title             String
  slug              String               @unique
  description       String?
  mode              TestMode             @default(PRACTICE)
  structureType     TestStructureType    @default(SINGLE)
  visibilityStatus  TestVisibilityStatus @default(DRAFT)
  totalQuestions    Int                  @default(0)
  totalMarks        Float                @default(0)
  durationInMinutes Int?
  startAt           DateTime?
  endAt             DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  createdBy     User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  sections      TestSection[]
  testQuestions TestQuestion[]
  attempts      TestAttempt[]
  testBatches   TestBatch[]
}

model TestSection {
  id                String   @id @default(cuid())
  testId            String
  title             String
  displayOrder      Int      @default(0)
  totalQuestions    Int      @default(0)
  durationInMinutes Int?
  positiveMarks     Float?
  negativeMarks     Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  test          Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  testQuestions TestQuestion[]
}

model TestQuestion {
  id            String   @id @default(cuid())
  testId        String
  questionId    String
  sectionId     String?
  displayOrder  Int      @default(0)
  positiveMarks Float?
  negativeMarks Float?
  createdAt     DateTime @default(now())

  test     Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  section  TestSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  answers  AttemptAnswer[]

  @@unique([testId, questionId])
}

model TestAttempt {
  id                 String        @id @default(cuid())
  testId             String
  userId             String
  status             AttemptStatus @default(NOT_STARTED)
  startedAt          DateTime?
  submittedAt        DateTime?
  totalMarksObtained Float?
  correctCount       Int           @default(0)
  wrongCount         Int           @default(0)
  unansweredCount    Int           @default(0)
  rank               Int?
  percentage         Float?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  test    Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers AttemptAnswer[]

  @@unique([testId, userId])
}

model AttemptAnswer {
  id              String   @id @default(cuid())
  attemptId       String
  testQuestionId  String
  selectedAnswer  String?
  markedForReview Boolean  @default(false)
  isAnswered      Boolean  @default(false)
  isCorrect       Boolean?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attempt      TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  testQuestion TestQuestion @relation(fields: [testQuestionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, testQuestionId])
}

/// Exam streams supported by the academy.
/// Add more later as your product expands.
enum ExamType {
  UPSC
  GPSC
  WPSI
  TECHNICAL_OPERATOR
  OTHER
}

/// Batch lifecycle status.
enum BatchStatus {
  DRAFT
  ACTIVE
  CLOSED
}

/// Main batch entity.
///
/// Purpose:
/// - group students by exam/program
/// - later link tests, payments, content access, announcements, etc.
model Batch {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?
  examType    ExamType
  status      BatchStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  isPaid      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  /// If your User model already exists, this relation assumes:
  /// User.id is String and the admin user creates the batch.
  createdById String?
  createdBy   User?   @relation("BatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  testBatches TestBatch[]

  /// Junction relation to students.
  studentBatches StudentBatch[]
}

/// Junction table between student users and batches.
///
/// Why a junction table instead of a direct field?
/// - one student can belong to multiple batches
/// - future flexibility for active/inactive membership
/// - easy auditability
model StudentBatch {
  id         String   @id @default(cuid())
  studentId  String
  batchId    String
  assignedAt DateTime @default(now())

  student User  @relation("StudentBatchMembership", fields: [studentId], references: [id], onDelete: Cascade)
  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([studentId, batchId])
}

model TestBatch {
  id         String   @id @default(cuid())
  testId     String
  batchId    String
  assignedAt DateTime @default(now())

  test  Test  @relation(fields: [testId], references: [id], onDelete: Cascade)
  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([testId, batchId])
  @@index([testId])
  @@index([batchId])
}
